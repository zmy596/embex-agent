# Python runtime used by the ESP tool layer.
ESP_AGENT_PYTHON=D:\code\anaconda\envs\yd-agent\python.exe

# Optional OpenAI-compatible LLM / LangChain agent.
# Frontend settings can override these per request.
LLM_ENABLED=false
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_API_KEY=
